{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dock Digits",
  "version": "0.1.0",
  "identifier": "com.muralipuvvada.dock-digits",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "visible": false,
        "title": "Dock Digits",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMyNzU1RkU3QjFDQTk0NEYKUldSUGxNcXg1MTkxTWptUXVLUFJLQmEyU2tzcnRONks2dWxrRGFsK1RWYVJTSzVaUlJrZExhMEoK",
      "endpoints": [
        "https://github.com/Murali-Puvvada/dock-digits/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
