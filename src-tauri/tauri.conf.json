{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dock-digits",
  "version": "0.1.0",
  "identifier": "com.muralipuvvada.dock-digits",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "visible": false,
        "title": "dock-digits",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "updater": {
    "active": true,
    "endpoints": [
      "https://github.com/Murali-Puvvada/dock-digits/releases/latest/download/latest.json"
    ]
  }
}
